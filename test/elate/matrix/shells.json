{
  "name": "evil-ghostel-shells",
  "comment": "evil-ghostel operator/motion matrix across shells. Drive one shell per `elate run` with --set shell=.. --set echo=.. --set setup=.. (co-varying, so not a `matrix --param` Cartesian axis). Use --keep-going so every group reports. Each group types a command, applies an Evil edit over the PTY, executes it, and asserts the output -- the shell proves the edit landed. Per-shell known failures ride on the failing `wait` step via `expect: {{u_expect}}/{{P_expect}}` (default pass; set to fail for nu).",
  "params": {
    "shell": "/opt/homebrew/bin/bash",
    "echo": "echo",
    "setup": "",
    "u_expect": "pass",
    "P_expect": "pass"
  },
  "session": {
    "ui": "tty",
    "size": "120x40",
    "config": "minimal",
    "eval": [
      "(load \"/Users/daniel/.emacs.d/lib/ghostel/test/elate/lib/evil-ghostel-setup.el\")",
      "(setq ghostel-shell \"{{shell}}\")"
    ]
  },
  "steps": [
    {"eval": "(ghostel)"},
    {"wait": "idle", "min_idle": 1.0, "timeout": 15.0},

    {"group": "setup", "comment": "per-shell prep: normalize prompt / define an echo-like helper"},
    {"type": "{{setup}}"},
    {"keys": "RET"},
    {"wait": "idle", "min_idle": 0.5, "timeout": 5.0},

    {"group": "i", "comment": "i + RET (baseline typing)"},
    {"type": "{{echo}} m01ok"},
    {"keys": "RET"},
    {"wait": "text", "pattern": "^m01ok$", "timeout": 8.0},

    {"group": "A", "comment": "append at end of input"},
    {"type": "{{echo}} m02"},
    {"keys": "<escape> A"},
    {"type": "-ok"},
    {"keys": "RET"},
    {"wait": "text", "pattern": "^m02-ok$", "timeout": 8.0},

    {"group": "I", "comment": "insert at start of input"},
    {"type": "m03ok"},
    {"keys": "<escape> I"},
    {"type": "{{echo}} "},
    {"keys": "RET"},
    {"wait": "text", "pattern": "^m03ok$", "timeout": 8.0},

    {"group": "x", "comment": "$ then x -- delete last char"},
    {"type": "{{echo}} m04okZ"},
    {"keys": "<escape> $ x"},
    {"keys": "A"},
    {"keys": "RET"},
    {"wait": "text", "pattern": "^m04ok$", "timeout": 8.0},

    {"group": "dw", "comment": "delete word"},
    {"type": "{{echo}} DELME m05ok"},
    {"keys": "<escape> ^ w d w"},
    {"keys": "A"},
    {"keys": "RET"},
    {"wait": "text", "pattern": "^m05ok$", "timeout": 8.0},

    {"group": "2dw", "comment": "delete two words (count)"},
    {"type": "{{echo}} aa bb m06ok"},
    {"keys": "<escape> ^ w 2 d w"},
    {"keys": "A"},
    {"keys": "RET"},
    {"wait": "text", "pattern": "^m06ok$", "timeout": 8.0},

    {"group": "cw", "comment": "change word, then type replacement"},
    {"type": "{{echo}} BAD"},
    {"keys": "<escape> ^ w c w"},
    {"type": "m07ok"},
    {"keys": "<escape> A"},
    {"keys": "RET"},
    {"wait": "text", "pattern": "^m07ok$", "timeout": 8.0},

    {"group": "dd", "comment": "delete whole input line, then retype"},
    {"type": "{{echo}} NOPE_dd"},
    {"keys": "<escape> d d"},
    {"keys": "i"},
    {"type": "{{echo}} m08ok"},
    {"keys": "RET"},
    {"wait": "text", "pattern": "^m08ok$", "timeout": 8.0},

    {"group": "cc", "comment": "change whole input line"},
    {"type": "{{echo}} NOPE_cc"},
    {"keys": "<escape> c c"},
    {"type": "{{echo}} m09ok"},
    {"keys": "<escape> A"},
    {"keys": "RET"},
    {"wait": "text", "pattern": "^m09ok$", "timeout": 8.0},

    {"group": "D", "comment": "delete from cursor to end of input"},
    {"type": "{{echo}} m10ok DELTAIL"},
    {"keys": "<escape> ^ w w D"},
    {"keys": "A"},
    {"keys": "RET"},
    {"wait": "text", "pattern": "^m10ok$", "timeout": 8.0},

    {"group": "C", "comment": "change from cursor to end of input"},
    {"type": "{{echo}} m11 BADTAIL"},
    {"keys": "<escape> ^ w w C"},
    {"type": "ok"},
    {"keys": "<escape> A"},
    {"keys": "RET"},
    {"wait": "text", "pattern": "^m11 ok$", "timeout": 8.0},

    {"group": "r", "comment": "replace single char"},
    {"type": "{{echo}} m12oZ"},
    {"keys": "<escape> $ r k"},
    {"keys": "A"},
    {"keys": "RET"},
    {"wait": "text", "pattern": "^m12ok$", "timeout": 8.0},

    {"group": "3r", "comment": "replace three chars with a count"},
    {"type": "{{echo}} ZZZm13"},
    {"keys": "<escape> ^ w 3 r o"},
    {"keys": "A"},
    {"keys": "RET"},
    {"wait": "text", "pattern": "^ooom13$", "timeout": 8.0},

    {"group": "u", "comment": "x then u -- undo restores the deleted char"},
    {"type": "{{echo}} m14okX"},
    {"keys": "<escape> $ x"},
    {"keys": "u"},
    {"keys": "A"},
    {"keys": "RET"},
    {"wait": "text", "pattern": "^m14okX$", "timeout": 8.0,
     "expect": "{{u_expect}}", "reason": "nu/reedline does not bind C-_ (readline/zle undo) that evil-ghostel-undo sends"},

    {"group": "visual", "comment": "v e d -- select a word and delete it"},
    {"type": "{{echo}} VISME m15ok"},
    {"keys": "<escape> ^ w v e d"},
    {"keys": "A"},
    {"keys": "RET"},
    {"wait": "text", "pattern": "^m15ok$", "timeout": 8.0},

    {"group": "a", "comment": "append after cursor (vs A at end)"},
    {"type": "{{echo}} ak"},
    {"keys": "<escape> ^ w a"},
    {"type": "X"},
    {"keys": "<escape> A"},
    {"keys": "RET"},
    {"wait": "text", "pattern": "^aXk$", "timeout": 8.0},

    {"group": "X", "comment": "delete char before cursor"},
    {"type": "{{echo}} okk"},
    {"keys": "<escape> $ X"},
    {"keys": "A"},
    {"keys": "RET"},
    {"wait": "text", "pattern": "^ok$", "timeout": 8.0},

    {"group": "s", "comment": "substitute char (delete + insert)"},
    {"type": "{{echo}} Zok"},
    {"keys": "<escape> ^ w s"},
    {"type": "s"},
    {"keys": "<escape> A"},
    {"keys": "RET"},
    {"wait": "text", "pattern": "^sok$", "timeout": 8.0},

    {"group": "S", "comment": "substitute whole line"},
    {"type": "{{echo}} NOPE_S"},
    {"keys": "<escape> S"},
    {"type": "{{echo}} Sok"},
    {"keys": "<escape> A"},
    {"keys": "RET"},
    {"wait": "text", "pattern": "^Sok$", "timeout": 8.0},

    {"group": "p", "comment": "yank a word then paste after"},
    {"type": "{{echo}} dup"},
    {"keys": "<escape> ^ w y w"},
    {"keys": "A"},
    {"type": " "},
    {"keys": "<escape> p"},
    {"keys": "A"},
    {"keys": "RET"},
    {"wait": "text", "pattern": "^dup dup$", "timeout": 8.0},

    {"group": "P", "comment": "yank a word then paste before"},
    {"type": "{{echo}} ok"},
    {"keys": "<escape> ^ w y w P"},
    {"keys": "A"},
    {"keys": "RET"},
    {"wait": "text", "pattern": "^okok$", "timeout": 8.0,
     "expect": "{{P_expect}}", "reason": "nu/reedline paste-before inserts nothing (paste-after works)"},

    {"group": "C-w", "comment": "insert-mode C-w passthrough: delete word backward"},
    {"type": "{{echo}} BADWORD"},
    {"keys": "C-w"},
    {"type": "good"},
    {"keys": "RET"},
    {"wait": "text", "pattern": "^good$", "timeout": 8.0},

    {"group": "C-u", "comment": "insert-mode C-u passthrough: kill line"},
    {"type": "GARBAGE"},
    {"keys": "C-u"},
    {"type": "{{echo}} cuok"},
    {"keys": "RET"},
    {"wait": "text", "pattern": "^cuok$", "timeout": 8.0},

    {"group": "C-a/C-e", "comment": "insert-mode C-a/C-e passthrough: line start / end"},
    {"type": "world"},
    {"keys": "C-a"},
    {"type": "{{echo}} "},
    {"keys": "C-e"},
    {"keys": "RET"},
    {"wait": "text", "pattern": "^world$", "timeout": 8.0},

    {"group": ".", "comment": ". repeats the last change (dw here)"},
    {"type": "{{echo}} aa bb cc"},
    {"keys": "<escape> ^ w d w ."},
    {"keys": "A"},
    {"keys": "RET"},
    {"wait": "text", "pattern": "^cc$", "timeout": 8.0},

    {"group": "~", "comment": "~ toggle-case"},
    {"type": "{{echo}} aBC"},
    {"keys": "<escape> ^ w ~", "expect": "fail", "reason": "~ is not remapped to a PTY-routed op, so vanilla Evil tries to edit the read-only *ghostel* render buffer and signals `Buffer is read-only`"},
    {"keys": "A"},
    {"keys": "RET"},
    {"wait": "text", "pattern": "^ABC$", "timeout": 8.0,
     "expect": "fail", "reason": "consequently the input is unchanged, so the toggled-case output never appears"}
  ]
}
