{
  "name": "boundary-nu-ghostel",
  "comment": "Input-region boundary matrix (nu on ghostel): autosuggestion / right-prompt / soft-wrap / syntax-tail edges that the generic operator matrix never exercises live. Run with --keep-going. Reset (SIGINT + insert) before each op.",
  "session": {
    "ui": "tty",
    "size": "120x40",
    "config": "minimal",
    "env": {},
    "eval": [
      "(load \"/Users/daniel/.emacs.d/lib/ghostel/test/elate/lib/evil-ghostel-setup.el\")",
      "(setq ghostel-shell \"/opt/homebrew/bin/nu\")"
    ]
  },
  "steps": [
    {
      "eval": "(ghostel)"
    },
    {
      "wait": "idle",
      "min_idle": 1.0,
      "timeout": 15.0
    },
    {
      "group": "prompt",
      "comment": "short prompt + shell helpers"
    },
    {
      "type": "$env.PROMPT_COMMAND = {|| \"> \" }; $env.PROMPT_COMMAND_RIGHT = {|| \"\" }; $env.PROMPT_INDICATOR = {|| \"\" }"
    },
    {
      "keys": "RET"
    },
    {
      "wait": "idle",
      "min_idle": 0.5,
      "timeout": 5.0
    },
    {
      "type": "def e [...rest] { $rest | str join \" \" }"
    },
    {
      "keys": "RET"
    },
    {
      "wait": "idle",
      "min_idle": 0.5,
      "timeout": 5.0
    },
    {
      "group": "sanity",
      "comment": "baseline typing + exec works"
    },
    {
      "type": "e sane01"
    },
    {
      "keys": "RET"
    },
    {
      "wait": "text",
      "pattern": "^sane01$",
      "timeout": 8.0
    },
    {
      "group": "A1-dollar",
      "comment": "$ then a X: end-of-line must clamp to typed end"
    },
    {
      "type": "e hello world"
    },
    {
      "keys": "RET"
    },
    {
      "wait": "text",
      "pattern": "^hello world$",
      "timeout": 8.0
    },
    {
      "type": "e hello"
    },
    {
      "wait": "idle",
      "min_idle": 1.3,
      "timeout": 8.0
    },
    {
      "eval": "(let ((l (buffer-substring-no-properties (line-beginning-position) (line-end-position)))) (unless (string-match-p \"e hello world\" l) (error \"NO-LIVE-GHOST: %s\" l)))"
    },
    {
      "keys": "<escape> $ a"
    },
    {
      "type": "X"
    },
    {
      "keys": "RET"
    },
    {
      "wait": "text",
      "pattern": "^helloX$",
      "timeout": 8.0
    },
    {
      "group": "A2-append",
      "comment": "A: append-at-end must land at typed end"
    },
    {
      "type": "e hello world"
    },
    {
      "keys": "RET"
    },
    {
      "wait": "text",
      "pattern": "^hello world$",
      "timeout": 8.0
    },
    {
      "type": "e hello"
    },
    {
      "wait": "idle",
      "min_idle": 1.3,
      "timeout": 8.0
    },
    {
      "eval": "(let ((l (buffer-substring-no-properties (line-beginning-position) (line-end-position)))) (unless (string-match-p \"e hello world\" l) (error \"NO-LIVE-GHOST: %s\" l)))"
    },
    {
      "keys": "<escape> A"
    },
    {
      "type": "X"
    },
    {
      "keys": "RET"
    },
    {
      "wait": "text",
      "pattern": "^helloX$",
      "timeout": 8.0
    },
    {
      "group": "B-rp-on",
      "comment": "enable a right prompt '[RP]'"
    },
    {
      "type": "$env.PROMPT_COMMAND_RIGHT = {|| \"[RP]\" }"
    },
    {
      "keys": "RET"
    },
    {
      "wait": "idle",
      "min_idle": 0.5,
      "timeout": 5.0
    },
    {
      "group": "B1-append",
      "comment": "A X with a right prompt: must append after 'hi', not [RP]"
    },
    {
      "type": "e hi"
    },
    {
      "keys": "<escape> A"
    },
    {
      "type": "X"
    },
    {
      "keys": "RET"
    },
    {
      "wait": "text",
      "pattern": "^hiX$",
      "timeout": 8.0
    },
    {
      "group": "B2-delete",
      "comment": "^ D then retype: D must delete only typed input, not [RP]"
    },
    {
      "type": "e hi"
    },
    {
      "keys": "<escape> ^ D"
    },
    {
      "keys": "i"
    },
    {
      "type": "e ok"
    },
    {
      "keys": "RET"
    },
    {
      "wait": "text",
      "pattern": "^ok$",
      "timeout": 8.0
    },
    {
      "group": "B-rp-off",
      "comment": "disable the right prompt"
    },
    {
      "type": "$env.PROMPT_COMMAND_RIGHT = {|| \"\" }"
    },
    {
      "keys": "RET"
    },
    {
      "wait": "idle",
      "min_idle": 0.5,
      "timeout": 5.0
    },
    {
      "group": "D1-delete-tail",
      "comment": "^ w w D: delete colored 'bar' tail to end"
    },
    {
      "type": "e foo bar"
    },
    {
      "keys": "<escape> ^ w w D"
    },
    {
      "keys": "A"
    },
    {
      "keys": "RET"
    },
    {
      "wait": "text",
      "pattern": "^foo$",
      "timeout": 8.0
    },
    {
      "group": "D2-change-tail",
      "comment": "^ w w C baz: change colored 'bar' tail"
    },
    {
      "type": "e foo bar"
    },
    {
      "keys": "<escape> ^ w w C"
    },
    {
      "type": "baz"
    },
    {
      "keys": "<escape> A"
    },
    {
      "keys": "RET"
    },
    {
      "wait": "text",
      "pattern": "^foo baz$",
      "timeout": 8.0
    },
    {
      "group": "M1-build",
      "comment": "open quote + ENTER builds a 2-line input that executes"
    },
    {
      "type": "e \"mlA"
    },
    {
      "keys": "RET"
    },
    {
      "type": "mlB\""
    },
    {
      "keys": "RET"
    },
    {
      "wait": "text",
      "pattern": "^mlB$",
      "timeout": 8.0
    }
  ]
}
